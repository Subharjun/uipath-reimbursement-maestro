        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:(vars.caseManagerDecisions.stagesExited == null || vars.caseManagerDecisions.stagesExited.length == 0 || !vars.caseManagerDecisions.stagesExited.some((stage) =&gt; stage.stageName == 'Intake' || stage.stageName == 'IDP Digitize' || stage.stageName == 'Classification' || stage.stageName == 'Payment Processing' || stage.stageName == 'Closure Notification' || stage.stageName == 'Reject')) &amp;&amp; (vars.caseManagerDecisions.stagesCompleted == null || vars.caseManagerDecisions.stagesCompleted.length == 0 || !vars.caseManagerDecisions.stagesCompleted.some((stage) =&gt; stage.stageName == 'Intake' || stage.stageName == 'IDP Digitize' || stage.stageName == 'Classification' || stage.stageName == 'Payment Processing' || stage.stageName == 'Closure Notification' || stage.stageName == 'Reject'))</bpmn:conditionExpression>
